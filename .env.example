DISCORD_TOKEN=your-discord-bot-token
TARGET_CHANNEL_ID=123456789012345678

# fxtwitter.com and vxtwitter.com are common embed-friendly Twitter/X frontends.
REPLACEMENT_DOMAIN=fxtwitter.com

# false: bot posts a converted link below the original message.
# true: bot tries to delete the original after posting/reposting the converted link.
DELETE_ORIGINAL=false

# false: bot sends the converted message as itself.
# true: bot reposts through a channel webhook using the original author's display name/avatar.
# Requires Manage Webhooks. Best paired with DELETE_ORIGINAL=true.
USE_WEBHOOK=false

# Adds a mention of the original author when USE_WEBHOOK=false.
INCLUDE_ORIGINAL_AUTHOR=true

# Coolify can use this for a health check.
HEALTH_PORT=3000
